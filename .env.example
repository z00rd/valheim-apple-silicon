# Copy to .env and fill in:  cp .env.example .env
SERVER_NAME="Server Name"
SERVER_PASS="CHANGE_ME_min5chars"
WORLD_NAME="WorldName"
TZ="Europe/Warsaw"

# Optional: Google Drive folder for backups (e.g. ~/Library/CloudStorage/GoogleDrive-.../My Drive/valheim-backups)
GDRIVE_DIR=""

# --- Only for the "simple" variant with the Tailscale sidecar inside the VM (docker-compose.sidecar.yml).
# The default architecture runs Tailscale on the HOST (one-time `tailscale up`), so these are NOT needed.
# Auth key: https://login.tailscale.com/admin/settings/keys (Reusable, not Ephemeral)
TS_AUTHKEY="tskey-auth-PASTE-HERE"
TS_HOSTNAME="valheim-server"
